/* cxWidgets UML Class Diagram - GraphViz format
 * Source: ../src/
 * Generated from C++ classes in ../src/*.h
 *
 * To regenerate PNG from this directory:
 *   dot -Tpng -o cxWidgets_class_diagram.png cxWidgets_classes.dot
 */
digraph cxWidgets_UML {
    rankdir=BT;
    node [shape=record, fontname="Helvetica", fontsize=10];
    edge [arrowhead=empty];

    /* Core Base */
    cxObject [label="{cxObject|+ UseColors() : bool\l+ UseBeeps() : bool\l+ beep()\l+ cxTypeStr() : string\l}"];

    cxApp [label="{cxApp|+ mainLoop() : long\l+ run() : long\l+ onInit() : long\l+ onExit() : long\l}"];
    cxApp -> cxObject;

    /* Main Window Hierarchy */
    cxWindow [label="{cxWindow|+ show()\l+ showModal() : long\l+ draw()\l+ hide()\l+ move() : bool\l+ resize() : bool\l+ touchWindow()\l}"];
    cxWindow -> cxObject;

    cxButton [label="{cxButton|+ showModal() : long\l+ setOnClickFunction()\l+ runOnClickFunction() : string\l}"];
    cxButton -> cxWindow;

    cxDialog [label="{cxDialog|+ showModal() : long\l}"];
    cxDialog -> cxWindow;

    cxMessageDialog [label="{cxMessageDialog|+ showModal() : long\l}"];
    cxMessageDialog -> cxDialog;

    cxFrame [label="{cxFrame|}"];
    cxFrame -> cxWindow;

    cxLabel [label="{cxLabel|+ getText() : string\l+ setText()\l}"];
    cxLabel -> cxWindow;

    cxPanel [label="{cxPanel|+ showModal() : long\l+ append() : bool\l+ getWindow()\l+ delWindow()\l+ numWindows() : unsigned\l}"];
    cxPanel -> cxWindow;

    cxNotebook [label="{cxNotebook|+ showModal() : long\l+ append()\l+ getPanel()\l+ setCurrentWindow() : bool\l}"];
    cxNotebook -> cxPanel;

    cxSearchPanel [label="{cxSearchPanel|+ getForm()\l+ getMenu()\l+ appendToForm()\l+ appendToMenu()\l}"];
    cxSearchPanel -> cxPanel;

    cxForm [label="{cxForm|+ append()\l+ showModal() : long\l+ setCurrentInput() : bool\l}"];
    cxForm -> cxWindow;

    cxMultiForm [label="{cxMultiForm|}"];
    cxMultiForm -> cxForm;

    cxMenu [label="{cxMenu|+ append()\l+ remove() : bool\l+ showModal() : long\l}"];
    cxMenu -> cxWindow;

    cxMenuBar [label="{cxMenuBar|+ addMenu()\l+ showModal() : long\l+ showModalWithClick() : long\l+ getLastMenuReturnCode() : long\l}"];
    cxMenuBar -> cxWindow;

    cxScrolledWindow [label="{cxScrolledWindow|+ showModal() : long\l+ draw()\l}"];
    cxScrolledWindow -> cxWindow;

    cxFileViewer [label="{cxFileViewer|+ show() : long\l+ load()\l+ widestLine() : int\l}"];
    cxFileViewer -> cxScrolledWindow;

    cxGrid [label="{cxGrid|+ show() : long\l+ showModal() : long\l+ draw()\l+ getCellValue() : string\l+ setCellValue()\l}"];
    cxGrid -> cxWindow;

    cxDatePicker [label="{cxDatePicker|+ showModal() : long\l+ getSelectedDate() : cxDate\l}"];
    cxDatePicker -> cxWindow;

    cxOpenFileDialog [label="{cxOpenFileDialog|+ showModal() : long\l+ addFilter()\l+ setDirectory()\l+ getSelectedFilePath() : string\l}"];
    cxOpenFileDialog -> cxWindow;

    /* Input Hierarchy */
    cxMultiLineInput [label="{cxMultiLineInput|+ showModal() : long\l+ getValue() : string\l+ setValue()\l}"];
    cxMultiLineInput -> cxWindow;

    cxInput [label="{cxInput|+ showModal() : long\l+ getValue() : string\l+ setValue()\l}"];
    cxInput -> cxWindow;

    cxComboBox [label="{cxComboBox|+ appendToMenu()\l+ removeFromMenu()\l+ toggleMenu()\l}"];
    cxComboBox -> cxMultiLineInput;

    floatingPtInputWithRightLabel [label="{floatingPtInputWithRightLabel|}"];
    floatingPtInputWithRightLabel -> cxMultiLineInput;

    /* Function Callback Hierarchy */
    cxFunction [label="{«abstract»\ncxFunction|+ runFunction() : string\l+ functionIsSet() : bool\l}", style=filled, fillcolor=lightgray];
    cxFunction0 [label="{cxFunction0|}"];
    cxFunction0 -> cxFunction;
    cxFunction2 [label="{cxFunction2|}"];
    cxFunction2 -> cxFunction;
    cxFunction4 [label="{cxFunction4|}"];
    cxFunction4 -> cxFunction;

    /* Standalone classes */
    cxDate [label="{cxDate|+ getYear() : int\l+ getMonth() : int\l+ getDay() : int\l}", style=filled, fillcolor=lightyellow];
    cxWidgetsException [label="{cxWidgetsException|+ getErrorMsg() : string\l}", style=filled, fillcolor=lightyellow];
    cxTimer [label="{cxTimer|+ start()\l+ stop()\l+ delay()\l}", style=filled, fillcolor=lightyellow];
    cxTextValidator [label="{cxTextValidator|+ textIsValid() : bool\l+ addImpliedChars() : string\l}", style=filled, fillcolor=lightyellow];

    /* cxBase namespace (utility functions, not a class) */
    cxBase_ns [label="{«namespace»\ncxBase|+ init()\l+ cleanup()\l+ messageBox()\l+ promptYesNo() : bool\l+ updateWindows()\l+ writeText()\l}", style=filled, fillcolor=lightblue, shape=record];

    /* Subgraphs for grouping */
    subgraph cluster_core {
        label="Core";
        cxObject;
        cxApp;
    }
    subgraph cluster_windows {
        label="Window Hierarchy";
        cxWindow;
        cxButton;
        cxLabel;
        cxDialog;
        cxMessageDialog;
        cxFrame;
        cxPanel;
        cxNotebook;
        cxSearchPanel;
        cxForm;
        cxMultiForm;
        cxMenu;
        cxMenuBar;
        cxScrolledWindow;
        cxFileViewer;
        cxGrid;
        cxDatePicker;
        cxOpenFileDialog;
    }
    subgraph cluster_inputs {
        label="Input Controls";
        cxMultiLineInput;
        cxInput;
        cxComboBox;
        floatingPtInputWithRightLabel;
    }
    subgraph cluster_functions {
        label="Callbacks";
        cxFunction;
        cxFunction0;
        cxFunction2;
        cxFunction4;
    }
    subgraph cluster_util {
        label="Utility";
        cxDate;
        cxWidgetsException;
        cxTimer;
        cxTextValidator;
        cxBase_ns;
    }
}
